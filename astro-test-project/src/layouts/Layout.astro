---
const { title = 'Todo' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#f6f3ed" />
		<meta name="description" content="A simple, focused todo app." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body><slot /></body>
</html>

<style is:global>
	:root { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #20201e; background: #f6f3ed; font-synthesis: none; }
	* { box-sizing: border-box; }
	html, body { min-height: 100%; }
	body { margin: 0; }
	button, input { font: inherit; }
	button { color: inherit; }
</style>
