---
const stats = [
  { value: '24/7', label: 'Support' },
  { value: '150+', label: 'Launches' },
  { value: '4.9/5', label: 'Rated' },
];

const variants = [
  {
    tag: 'Aurora',
    title: 'Bold gradients and fast action',
    description: 'Best for creative products that want motion, confidence, and a premium feel.',
    linkLabel: 'View style',
    className: 'variant--aurora',
  },
  {
    tag: 'Editorial',
    title: 'Calm typography with strong contrast',
    description: 'Ideal for agencies and portfolios that need clarity and a polished editorial tone.',
    linkLabel: 'View style',
    className: 'variant--editorial',
  },
  {
    tag: 'Minimal',
    title: 'Soft spacing and simple structure',
    description: 'Perfect for SaaS landing pages that need a clean, modern, conversion-focused frame.',
    linkLabel: 'View style',
    className: 'variant--minimal',
  },
];
---

<section class="hero-shell">
  <div class="hero">
    <div class="hero__content">
      <p class="eyebrow">Neon systems • dark mode</p>
      <h1>Build the future in a glow of code and light.</h1>
      <p class="description">
        A modern cyber landing experience with cinematic contrast, sharp typography, and immersive motion cues for testing bold product stories.
      </p>
      <div class="actions">
        <a href="#" class="btn btn--primary">Enter portal</a>
        <a href="#" class="btn btn--secondary">Watch demo</a>
      </div>
      <ul class="stats" aria-label="Highlights">
        {stats.map((item) => (
          <li>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="hero__visual" aria-hidden="true">
      <div class="card card--main">
        <div class="card__top">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="card__body">
          <div class="pill">Quantum launch</div>
          <h2>Neural Studio</h2>
          <p>Interfaces, motion systems, and product experiences.</p>
          <div class="mini-bars">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
      <div class="card card--floating">
        <p>Signal boost</p>
        <strong>+128%</strong>
      </div>
    </div>
  </div>

  <div class="variant-section">
    <div class="variant-heading">
      <p class="eyebrow">Style presets</p>
      <h2>Prototype a sharper digital atmosphere.</h2>
    </div>
    <div class="variant-grid">
      {variants.map((variant) => (
        <article class={`variant-card ${variant.className}`}>
          <p class="variant-card__tag">{variant.tag}</p>
          <h3>{variant.title}</h3>
          <p>{variant.description}</p>
          <a href="#" class="variant-card__link">{variant.linkLabel}</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1rem 2rem;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 3rem;
    padding: 1rem 0 2.5rem;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.12);
    color: #7dd3fc;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    border: 1px solid rgba(34, 211, 238, 0.25);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.15);
  }

  h1 {
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 1.05;
    margin: 0 0 1rem;
    color: #f8fafc;
    text-shadow: 0 0 24px rgba(34, 211, 238, 0.16);
  }

  .description {
    font-size: 1.05rem;
    color: #a5b4fc;
    max-width: 560px;
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn--primary {
    background: linear-gradient(135deg, #06b6d4, #8b5cf6);
    color: white;
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.2);
  }

  .btn--secondary {
    background: rgba(15, 23, 42, 0.7);
    color: #e2e8f0;
    border: 1px solid rgba(34, 211, 238, 0.25);
  }

  .stats {
    display: flex;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  .stats li {
    min-width: 90px;
    padding: 0.7rem 0.9rem;
    border-radius: 1rem;
    background: rgba(7, 11, 24, 0.72);
    border: 1px solid rgba(34, 211, 238, 0.16);
    backdrop-filter: blur(12px);
  }

  .stats strong {
    display: block;
    color: #f8fafc;
    font-size: 1.05rem;
  }

  .stats span {
    color: #8b9dff;
    font-size: 0.88rem;
  }

  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .card {
    background: rgba(8, 15, 30, 0.92);
    color: #f8fafc;
    border-radius: 1.5rem;
    box-shadow: 0 25px 60px rgba(2, 6, 23, 0.45);
    border: 1px solid rgba(34, 211, 238, 0.16);
  }

  .card--main {
    width: min(100%, 400px);
    padding: 1rem;
  }

  .card__top {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .card__top span {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: #22d3ee;
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.35);
  }

  .card__body {
    padding: 1rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
  }

  .pill {
    display: inline-block;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.14);
    color: #7dd3fc;
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.7rem;
  }

  .card__body h2 {
    margin: 0 0 0.35rem;
    font-size: 1.35rem;
    color: #f8fafc;
  }

  .card__body p {
    margin: 0 0 1rem;
    color: #cbd5e1;
  }

  .mini-bars {
    display: flex;
    gap: 0.4rem;
  }

  .mini-bars span {
    display: block;
    height: 0.75rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #22d3ee, #8b5cf6);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.24);
  }

  .mini-bars span:nth-child(1) { width: 50px; }
  .mini-bars span:nth-child(2) { width: 70px; }
  .mini-bars span:nth-child(3) { width: 90px; }

  .card--floating {
    position: absolute;
    right: -1rem;
    bottom: 2rem;
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card--floating p {
    margin: 0;
    color: #94a3b8;
    font-size: 0.9rem;
  }

  .card--floating strong {
    font-size: 1.25rem;
    color: #f8fafc;
  }

  .variant-section {
    padding-top: 1rem;
  }

  .variant-heading {
    margin-bottom: 1.2rem;
  }

  .variant-heading h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    color: white;
  }

  .variant-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .variant-card {
    border-radius: 1.25rem;
    padding: 1.15rem;
    min-height: 190px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 20px 45px rgba(2, 6, 23, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .variant-card h3 {
    margin: 0.4rem 0 0.55rem;
    font-size: 1.1rem;
    color: #f8fafc;
  }

  .variant-card p {
    margin: 0;
    color: #cbd5e1;
    line-height: 1.6;
  }

  .variant-card__tag {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(34, 211, 238, 0.14);
    color: #7dd3fc;
  }

  .variant-card__link {
    margin-top: 1rem;
    display: inline-flex;
    align-self: flex-start;
    font-weight: 700;
    color: #f8fafc;
    text-decoration: none;
  }

  .variant--aurora {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(59, 130, 246, 0.22));
  }

  .variant--editorial {
    background: linear-gradient(135deg, rgba(3, 7, 18, 0.95), rgba(30, 41, 59, 0.9));
  }

  .variant--minimal {
    background: linear-gradient(135deg, rgba(8, 15, 30, 0.95), rgba(139, 92, 246, 0.18));
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 2.5rem;
    }

    .hero__visual {
      margin-top: 1rem;
      padding-bottom: 1rem;
    }

    .variant-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
