---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing">
  <section class="page-card">
    <p class="eyebrow">Pricing</p>
    <h1>Compare routes in a simple flow.</h1>
    <p>
      This route keeps the layout light so you can focus on the navigation experience instead of heavy content.
    </p>
    <div class="panel">
      <strong>Starter</strong>
      <span>$19/mo</span>
    </div>
  </section>
</Layout>

<style>
  .page-card {
    max-width: 760px;
    margin: 2rem auto 0;
    padding: 2rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 50px rgba(2, 6, 23, 0.28);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #cbd5ff;
    font-size: 0.8rem;
    margin-bottom: 0.8rem;
  }

  h1 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 0 0 0.8rem;
    color: white;
  }

  p {
    color: #dbe4ff;
    line-height: 1.7;
  }

  .panel {
    margin-top: 1.2rem;
    padding: 1rem 1.2rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.12);
    display: flex;
    justify-content: space-between;
    color: white;
  }
</style>
