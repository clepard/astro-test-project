---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services">
  <section class="page-card">
    <p class="eyebrow">Services</p>
    <h1>Another route, another feel.</h1>
    <p>
      Use this page to view how a different route loads and renders with the same navigation shell.
    </p>
    <div class="grid">
      <article>Speed audits</article>
      <article>Performance reviews</article>
      <article>Design systems</article>
    </div>
  </section>
</Layout>

<style>
  .page-card {
    max-width: 860px;
    margin: 2rem auto 0;
    padding: 2rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 50px rgba(2, 6, 23, 0.28);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #cbd5ff;
    font-size: 0.8rem;
    margin-bottom: 0.8rem;
  }

  h1 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 0 0 0.8rem;
    color: white;
  }

  p {
    color: #dbe4ff;
    line-height: 1.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-top: 1.3rem;
  }

  .grid article {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-weight: 600;
  }
</style>
