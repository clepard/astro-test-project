---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="page-card">
    <p class="eyebrow">About</p>
    <h1>Fast pages for fast testing.</h1>
    <p>
      This section is a simple, lightweight destination so you can compare how quickly a new route appears.
    </p>
    <ul>
      <li>Clear content structure</li>
      <li>Minimal assets</li>
      <li>Easy to benchmark</li>
    </ul>
  </section>
</Layout>

<style>
  .page-card {
    max-width: 780px;
    margin: 2rem auto 0;
    padding: 2rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 50px rgba(2, 6, 23, 0.28);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #cbd5ff;
    font-size: 0.8rem;
    margin-bottom: 0.8rem;
  }

  h1 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 0 0 0.8rem;
    color: white;
  }

  p,
  li {
    color: #dbe4ff;
    line-height: 1.7;
  }

  ul {
    padding-left: 1.2rem;
  }
</style>
