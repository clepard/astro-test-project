	<script>
		const body = document.body;
		const menu = document.querySelector<HTMLElement>('[data-menu]');
		const menuButton = document.querySelector<HTMLButtonElement>('[data-menu-button]');
		const closeButtons = document.querySelectorAll<HTMLButtonElement>('[data-menu-close]');
		const visibleCloseButton = document.querySelector<HTMLButtonElement>('.menu-top [data-menu-close]');

		const setMenu = (open: boolean) => {
			body.classList.toggle('menu-open', open);
			menu?.classList.toggle('open', open);
			menu?.setAttribute('aria-hidden', String(!open));
			menuButton?.setAttribute('aria-expanded', String(open));
			if (open) {
				document.querySelector<HTMLElement>('[data-header]')?.classList.remove('is-hidden');
			}
			if (open) visibleCloseButton?.focus();
		};

		menuButton?.addEventListener('click', () => setMenu(true));
		closeButtons.forEach((button) => button.addEventListener('click', () => setMenu(false)));
		menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenu(false)));

		const submenuButtons = document.querySelectorAll<HTMLButtonElement>('[data-submenu-button]');
		submenuButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const group = button.closest<HTMLElement>('[data-nav-group]');
				const willOpen = !group?.classList.contains('open');

				document.querySelectorAll<HTMLElement>('[data-nav-group]').forEach((item) => {
					item.classList.remove('open');
					item.querySelector<HTMLButtonElement>('[data-submenu-button]')?.setAttribute('aria-expanded', 'false');
				});

				if (willOpen) {
					group?.classList.add('open');
					button.setAttribute('aria-expanded', 'true');
					window.setTimeout(() => {
						if (!group?.classList.contains('open')) return;
						const submenu = group?.querySelector<HTMLElement>('[data-submenu]');
						const firstLink = submenu?.querySelector<HTMLAnchorElement>('a');
						firstLink?.focus({ preventScroll: true });
						submenu?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
					}, 340);
				}
			});
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && menu?.classList.contains('open')) {
				setMenu(false);
				menuButton?.focus();
			}
		});

		const header = document.querySelector<HTMLElement>('[data-header]');
		let lastScrollY = Math.max(window.scrollY, 0);
		let headerTicking = false;

		const updateHeader = () => {
			const currentScrollY = Math.max(window.scrollY, 0);
			const scrollDifference = currentScrollY - lastScrollY;
			const menuIsOpen = menu?.classList.contains('open');

			if (!menuIsOpen && Math.abs(scrollDifference) >= 3) {
				header?.classList.toggle('is-hidden', currentScrollY > 50 && scrollDifference > 0);
			}

			if (currentScrollY <= 50 || scrollDifference < 0 || menuIsOpen) {
				header?.classList.remove('is-hidden');
			}

			lastScrollY = currentScrollY;
			headerTicking = false;
		};

		window.addEventListener('scroll', () => {
			if (!headerTicking) {
				window.requestAnimationFrame(updateHeader);
				headerTicking = true;
			}
		}, { passive: true });

		const categories = document.querySelectorAll<HTMLAnchorElement>('.category-strip a');
		categories.forEach((link) => link.addEventListener('click', () => {
			categories.forEach((item) => item.classList.toggle('active', item === link));
		}));

		const teamTrack = document.querySelector<HTMLElement>('[data-team-track]');
		const teamControls = document.querySelector<HTMLElement>('.team-section .carousel-controls');
		let teamCards = Array.from(teamTrack?.querySelectorAll<HTMLElement>('.team-card') ?? []);
		let teamIndex = 0;
		let teamScrollTimer: number | undefined;
		let teamResizeTimer: number | undefined;
		let teamLoopTimer: number | undefined;
		let teamAutoplayTimer: number | undefined;
		let teamIsAnimating = false;

		const teamCardLeft = (card: HTMLElement) => {
			if (!teamTrack) return 0;
			return teamTrack.scrollLeft + card.getBoundingClientRect().left - teamTrack.getBoundingClientRect().left;
		};

		const jumpToTeamCard = (card: HTMLElement) => {
			teamTrack?.scrollTo({ left: teamCardLeft(card), behavior: 'auto' });
		};

		const setupTeamCarousel = () => {
			if (!teamTrack || !teamControls) return;
			window.clearTimeout(teamLoopTimer);
			teamIsAnimating = false;
			teamTrack.querySelectorAll<HTMLElement>('[data-team-clone]').forEach((clone) => clone.remove());
			teamCards = Array.from(teamTrack.querySelectorAll<HTMLElement>('.team-card'));
			teamTrack.scrollTo({ left: 0, behavior: 'auto' });
			const allCardsVisible = teamTrack.scrollWidth <= teamTrack.clientWidth + 2;
			teamControls.classList.toggle('is-unneeded', allCardsVisible);
			if (allCardsVisible) {
				teamIndex = 0;
				return;
			}

			const beforeFragment = document.createDocumentFragment();
			const afterFragment = document.createDocumentFragment();
			teamCards.forEach((card, index) => {
				const beforeClone = card.cloneNode(true) as HTMLElement;
				const afterClone = card.cloneNode(true) as HTMLElement;
				beforeClone.dataset.teamClone = 'before';
				afterClone.dataset.teamClone = 'after';
				beforeClone.dataset.teamOriginalIndex = String(index);
				afterClone.dataset.teamOriginalIndex = String(index);
				beforeClone.setAttribute('aria-hidden', 'true');
				afterClone.setAttribute('aria-hidden', 'true');
				beforeClone.inert = true;
				afterClone.inert = true;
				beforeFragment.append(beforeClone);
				afterFragment.append(afterClone);
			});
			teamTrack.insertBefore(beforeFragment, teamCards[0]);
			teamTrack.append(afterFragment);
			teamIndex = 0;
			jumpToTeamCard(teamCards[0]);
		};

		const finishTeamLoop = () => {
			if (!teamTrack || !teamCards.length) return;
			if (teamIndex === teamCards.length) {
				teamIndex = 0;
				jumpToTeamCard(teamCards[0]);
			} else if (teamIndex === -1) {
				teamIndex = teamCards.length - 1;
				jumpToTeamCard(teamCards[teamIndex]);
			}
			teamIsAnimating = false;
		};

		const scrollTeam = (direction: number) => {
			if (!teamTrack || !teamCards.length || teamIsAnimating) return;
			teamIsAnimating = true;
			teamIndex += direction;
			const target = teamIndex === -1
				? teamTrack.querySelector<HTMLElement>(`[data-team-clone="before"][data-team-original-index="${teamCards.length - 1}"]`)
				: teamIndex === teamCards.length
					? teamTrack.querySelector<HTMLElement>('[data-team-clone="after"][data-team-original-index="0"]')
					: teamCards[teamIndex];
			if (!target) {
				teamIsAnimating = false;
				return;
			}
			teamTrack.scrollTo({ left: teamCardLeft(target), behavior: 'smooth' });
			window.clearTimeout(teamLoopTimer);
			teamLoopTimer = window.setTimeout(finishTeamLoop, 900);
		};

		const pauseTeamAutoplay = () => window.clearInterval(teamAutoplayTimer);
		const startTeamAutoplay = () => {
			pauseTeamAutoplay();
			teamAutoplayTimer = window.setInterval(() => {
				if (document.hidden || teamControls?.classList.contains('is-unneeded')) return;
				scrollTeam(1);
			}, 2000);
		};
		const manuallyScrollTeam = (direction: number) => {
			startTeamAutoplay();
			scrollTeam(direction);
		};

		document.querySelector('[data-team-prev]')?.addEventListener('click', () => manuallyScrollTeam(-1));
		document.querySelector('[data-team-next]')?.addEventListener('click', () => manuallyScrollTeam(1));
		teamTrack?.addEventListener('scroll', () => {
			window.clearTimeout(teamScrollTimer);
			teamScrollTimer = window.setTimeout(() => {
				if (teamIsAnimating || !teamTrack) return;
				const currentLeft = teamTrack.scrollLeft;
				const visibleCards = Array.from(teamTrack.querySelectorAll<HTMLElement>('.team-card'));
				const closest = visibleCards.reduce((current, card) =>
					Math.abs(teamCardLeft(card) - currentLeft) < Math.abs(teamCardLeft(current) - currentLeft) ? card : current
				);
				if (closest.dataset.teamClone) {
					teamIndex = Number(closest.dataset.teamOriginalIndex ?? 0);
					jumpToTeamCard(teamCards[teamIndex]);
				} else {
					teamIndex = teamCards.indexOf(closest);
				}
			}, 120);
		}, { passive: true });
		teamTrack?.addEventListener('scrollend', () => {
			if (!teamIsAnimating) return;
			window.clearTimeout(teamLoopTimer);
			finishTeamLoop();
		});
		teamTrack?.addEventListener('pointerenter', (event) => {
			if (event.pointerType === 'mouse') pauseTeamAutoplay();
		});
		teamTrack?.addEventListener('pointerleave', (event) => {
			if (event.pointerType === 'mouse') startTeamAutoplay();
		});
		teamTrack?.addEventListener('pointerdown', (event) => {
			if (event.pointerType !== 'mouse') pauseTeamAutoplay();
		});
		teamTrack?.addEventListener('pointerup', (event) => {
			if (event.pointerType !== 'mouse') startTeamAutoplay();
		});
		teamTrack?.addEventListener('focusin', pauseTeamAutoplay);
		teamTrack?.addEventListener('focusout', startTeamAutoplay);
		document.addEventListener('visibilitychange', () => {
			if (document.hidden) pauseTeamAutoplay();
			else startTeamAutoplay();
		});
		window.addEventListener('resize', () => {
			window.clearTimeout(teamResizeTimer);
			teamResizeTimer = window.setTimeout(setupTeamCarousel, 160);
		}, { passive: true });
		window.requestAnimationFrame(() => {
			setupTeamCarousel();
			startTeamAutoplay();
		});

		document.querySelectorAll<HTMLElement>('[data-year]').forEach((item) => {
			item.textContent = String(new Date().getFullYear());
		});
	</script>
</Layout>

