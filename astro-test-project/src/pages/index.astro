---
import Layout from '../layouts/Layout.astro';

const activities = [
	{
		title: 'Riedlentės',
		image: '/images/gsd24-179.webp',
		position: 'center 48%',
	},
	{
		title: 'BMX',
		image: '/images/aje-rugsj-21.webp',
		position: 'center 54%',
	},
	{
		title: 'Paspirtukai',
		image: '/images/skate-treniruote.webp',
		position: 'center',
	},
	{
		title: 'Riedučiai',
		image: '/images/aje-skate.webp',
		position: 'center 35%',
	},
];

const camps = [
	{
		title: 'Skate Camp',
		date: 'Birž. 17d.',
		description: 'Geriausias laikas skateparke tau ir tavo draugams.',
		place: 'AJE+ Skatepark',
		image: '/images/camp-section.webp',
	},
	{
		title: 'Scoot Camp',
		date: 'BBirž. 17d.',
		description: 'Paspirtukų stovykla norintiems augti greičiau.',
		place: 'AJE+ Skatepark',
		image: '/images/skate-treniruote.webp',
	},
	{
		title: 'Scoot Camp',
		date: 'LBirž. 17d.',
		description: 'Judėjimas, komanda ir nauji triukai visą savaitę.',
		place: 'AJE+ Skatepark',
		image: '/images/aje-rugsj-21.webp',
	},
];

const events = [
	{
		title: 'Susitikimai ir varžybos',
		status: 'Renginių naujienos',
		date: 'Naujos datos netrukus',
		place: 'AJE+ Skatepark, Klaipėda',
		image: '/images/renginiai-1.webp',
	},
	{
		title: 'Bendruomenės renginiai',
		status: 'Renginių naujienos',
		date: 'Sek naujienas Facebook',
		place: 'AJE+ Skatepark, Klaipėda',
		image: '/images/aje-rugsj-7.webp',
	},
	{
		title: 'Kūrybinės dirbtuvės',
		status: 'Renginių naujienos',
		date: 'Programa ruošiama',
		place: 'AJE+ Skatepark, Klaipėda',
		image: '/images/rectangle-image-27.webp',
	},
];

const services = [
	{
		id: 'gimtadieniai',
		number: '01',
		title: 'Tavo gimtadienis',
		text: 'Geriausias laikas skateparke kartu su draugais.',
		meta: 'Nuo 40 EUR',
		image: '/images/rectangle-27.webp',
	},
	{
		id: 'erdves-renginiams',
		number: '02',
		title: 'Erdvės renginiams',
		text: 'Patalpa ir įranga jūsų renginiams, susitikimams ir kūrybai.',
		meta: 'Nuoma',
		image: '/images/aje-skate-park-paremkite.webp',
	},
	{
		id: 'kulturos-edukacija',
		number: '03',
		title: 'Kultūros edukacija',
		text: 'Gatvės kultūros pamokos 7–12 klasių moksleiviams.',
		meta: '7 EUR / asmeniui',
		image: '/images/rectangle-image-27.webp',
	},
	{
		id: 'kiemelis-parduotuve',
		number: '04',
		title: 'Kiemelis + įrangos parduotuvė',
		text: 'Vieta susitikti, pailsėti ir rasti veikloms reikalingą įrangą.',
		meta: 'Atidaryta',
		image: '/images/aje-rugsj-7.webp',
	},
];

const team = [
	{
		name: 'Raimonda Šuopytė',
		role: 'AJE+ Skateparko vadovė / jaunimo darbuotoja',
		image: '/images/team-raimonda.webp',
		featured: true,
	},
	{
		name: 'Donatas Lukauskas',
		role: 'Riedlenčių instruktorius / jaunimo darbuotojas',
		image: '/images/team-donatas.webp',
	},
	{
		name: 'Ignat Širvinskij',
		role: 'Paspirtukų instruktorius',
		image: '/images/team-ignat.webp',
	},
	{
		name: 'Mantas Jankauskas',
		role: 'BMX instruktorius',
		image: '/images/team-mantas.webp',
	},
	{
		name: 'Skirmantas Skukauskas',
		role: 'Riedučių instruktorius',
		image: '/images/team-skirmantas.webp',
	},
];
---

<Layout>
	<header class="utility-header" data-header>
		<div class="utility-inner">
			<a class="mini-logo" href="#pradzia" aria-label="AJE+ Skatepark pradžia">
				<img src="/aje-skatepark-logo.svg" alt="" />
			</a>

			<div class="utility-actions">
				<a class="schedule-link" href="#tvarkarastis">Tvarkaraštis</a>
				<button class="menu-button" type="button" data-menu-button aria-label="Atidaryti meniu" aria-expanded="false" aria-controls="site-menu">
					<span>Meniu</span>
					<span class="menu-lines" aria-hidden="true"><i></i><i></i></span>
				</button>
			</div>
		</div>
	</header>

	<div class="menu-overlay" id="site-menu" data-menu aria-hidden="true">
		<div class="fullscreen-menu">
			<div class="menu-top">
				<a class="menu-logo" href="#pradzia" aria-label="AJE+ Skatepark pradžia"><img src="/aje-skatepark-logo.svg" alt="" /></a>
				<p>MENIU / AJE+ SKATEPARK</p>
				<button type="button" data-menu-close>Uždaryti <span class="close-icon" aria-hidden="true"></span></button>
			</div>

			<nav class="fullscreen-nav" aria-label="Visas meniu">
				<div class="nav-group" data-nav-group>
					<button class="nav-group-trigger" type="button" data-submenu-button aria-expanded="false">
						<span>Treniruotės</span>
						<i class="nav-chevron" aria-hidden="true"></i>
					</button>
					<div class="nav-submenu" data-submenu>
						<div>
							<a href="#treniruotes">Skate</a>
							<a href="#treniruotes">BMX</a>
							<a href="#treniruotes">Riedučių</a>
							<a href="#treniruotes">Paspirtukų</a>
							<a href="#atviros-sesijos">Atviros riedėjimo sesijos</a>
						</div>
					</div>
				</div>

				<a class="nav-main-link" href="#gimtadieniai"><span>Gimtadieniai</span></a>
				<a class="nav-main-link" href="#erdves-renginiams"><span>Erdvės renginiams</span></a>
				<a class="nav-main-link" href="#stovyklos"><span>Stovyklos</span></a>
				<a class="nav-main-link" href="#renginiai"><span>Renginiai</span></a>

				<div class="nav-group" data-nav-group>
					<button class="nav-group-trigger" type="button" data-submenu-button aria-expanded="false">
						<span>Apie</span>
						<i class="nav-chevron" aria-hidden="true"></i>
					</button>
					<div class="nav-submenu" data-submenu>
						<div>
							<a href="#apie">Apie mus</a>
							<a href="#treneris">Savanorystė</a>
							<a href="#kiemelis-parduotuve">AJE MERCH</a>
							<a href="#prisidek">Parama / skirti 1,2%</a>
							<a href="#kontaktai">Kontaktai</a>
						</div>
					</div>
				</div>
			</nav>

			<div class="menu-bottom">
				<div class="menu-contact">
					<span>Gluosnių skg. 2A-k2, Klaipėda</span>
					<a href="tel:+37065183405">+370 651 83405</a>
					<a href="mailto:ajeskatepark@gmail.com">ajeskatepark@gmail.com</a>
				</div>
				<div class="menu-actions">
					<a href="#tvarkarastis">Tvarkaraštis</a>
					<a href="mailto:ajeskatepark@gmail.com">Susisiekti</a>
				</div>
			</div>
		</div>
	</div>

	<main id="pradzia">
		<section class="panel hero-section">
			<img
				class="hero-photo"
				src="/images/aje-rugsj-79.webp"
				alt="Riedantis jaunuolis AJE+ Skateparke"
			/>
			<div class="hero-shade"></div>
			<div class="hero-content">
				<h1>Pirmas uždaras<br />riedėjimo parkas<br />Klaipėdoje</h1>
				<p>Tai vieta aktyviai veiklai, kūrybai ir saviraiškai, kur gimsta idėjos, stiprėja bendruomenė ir kiekvienas gali drąsiai išreikšti save.</p>
				<div class="hero-actions">
					<a class="pill pill-yellow" href="#treniruotes">Treniruotės su instruktoriumi <span class="icon-arrow" aria-hidden="true"></span></a>
					<a class="pill pill-light" href="#atviros-sesijos">Atviros sesijos <span class="icon-arrow" aria-hidden="true"></span></a>
				</div>
			</div>
		</section>

		<section class="panel editorial-section" id="treniruotes">
			<div class="section-title-row">
				<div>
					<p class="eyebrow">01 / VEIKLOS</p>
					<h2>Treniruotės<br />su instruktoriumi</h2>
				</div>
				<p>Pradėti gali kiekvienas. Mokomės saugiai, nuosekliai ir savo tempu — grupėje arba individualiai.</p>
			</div>

			<div class="activity-grid">
				{activities.map((activity) => (
					<article class="editorial-card">
						<a class="card-image" href="#kontaktai" aria-label={`${activity.title} – plačiau`}>
							<img src={activity.image} alt="" style={`object-position: ${activity.position}`} loading="lazy" />
							<span class="card-image-shade" aria-hidden="true"></span>
							<span class="card-overlay">
								<h3>{activity.title}</h3>
								<span class="text-link">Plačiau <span class="icon-arrow" aria-hidden="true"></span></span>
							</span>
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="panel sessions-section" id="atviros-sesijos">
			<div class="section-title-row">
				<div>
					<p class="eyebrow">02 / TVARKARAŠTIS</p>
					<h2>Atviros riedėjimo<br />sesijos</h2>
				</div>
				<p>Laikas laisvai važinėti, mokytis vieniems iš kitų ir būti bendruomenėje. Patirtis nebūtina.</p>
			</div>
			<div class="sessions-layout">
				<figure class="sessions-photo">
					<img
						src="/images/aje-skate-park-paremkite.webp"
						alt="AJE+ bendruomenė atviroje sesijoje"
						loading="lazy"
					/>
					<figcaption>ATVIRA ERDVĖ / VISIEMS RIEDANTIEMS</figcaption>
				</figure>
				<div class="session-info" id="tvarkarastis">
					<h3>Atvyk, kai parkas atviras laisvam riedėjimui.</h3>
					<div class="session-rows">
						<div><span>Darbo dienomis</span><strong>Pagal savaitės tvarkaraštį</strong></div>
						<div><span>Savaitgalį</span><strong>Skelbiama atskirai</strong></div>
						<div><span>Vieta</span><strong>AJE+ Skatepark</strong></div>
					</div>
					<a class="pill pill-dark" href="mailto:ajeskatepark@gmail.com?subject=Atvirų sesijų tvarkaraštis">Žiūrėti tvarkaraštį <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
				</div>
			</div>
		</section>

		<section class="panel services-section" id="paslaugos">
			<div class="section-title-row">
				<div>
					<p class="eyebrow">03 / PASLAUGOS</p>
					<h2>Kitos<br />paslaugos</h2>
				</div>
				<p>Skateparkas gali tapti tavo šventės, renginio, pamokos ar tiesiog gero susitikimo vieta.</p>
			</div>
			<div class="service-grid">
				{services.map((service) => (
					<a class="service-card" id={service.id} href="#kontaktai">
						<figure><img src={service.image} alt="" loading="lazy" /><span>{service.number}</span></figure>
						<div class="service-card-copy">
							<p class="meta">{service.meta}</p>
							<h3>{service.title}</h3>
							<p>{service.text}</p>
							<span class="icon-arrow icon-arrow--up" aria-hidden="true"></span>
						</div>
					</a>
				))}
			</div>
		</section>

		<section class="panel camps-section" id="stovyklos">
			<div class="section-title-row">
				<div>
					<p class="eyebrow">04 / VASARA</p>
					<h2>Vasaros<br />stovyklos</h2>
				</div>
				<p>Intensyvus laikas judėti, mokytis, susipažinti ir parsivežti daugiau drąsos nei atsivežei.</p>
			</div>

			<div class="editorial-carousel camp-carousel">
				{camps.map((camp) => (
					<article class="compact-card camp-card">
						<div class="camp-card-heading">
							<div><h3>{camp.title}</h3><strong>{camp.date}</strong></div>
							<p>{camp.description}</p>
						</div>
						<a href="mailto:ajeskatepark@gmail.com?subject=Stovyklos registracija" class="compact-card-image" aria-label={`${camp.title} – plačiau`}>
							<img src={camp.image} alt="" loading="lazy" />
							<span class="compact-card-shade" aria-hidden="true"></span>
							<span class="camp-card-cta">Plačiau <span class="icon-arrow" aria-hidden="true"></span></span>
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="panel events-section" id="renginiai">
			<div class="section-title-row compact">
				<div>
					<p class="eyebrow">05 / KALENDORIUS</p>
					<h2>Renginiai</h2>
				</div>
				<a class="text-link" href="https://www.facebook.com/ajeskatepark" target="_blank" rel="noreferrer">Sekti Facebook <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
			</div>

			<div class="editorial-carousel event-carousel">
				{events.map((event) => (
					<article class="compact-card event-card">
						<a href="https://www.facebook.com/ajeskatepark" target="_blank" rel="noreferrer" aria-label={`${event.title} – plačiau`}>
							<span class="event-card-image"><img src={event.image} alt="" loading="lazy" /></span>
							<div class="event-card-body">
								<h3>{event.title}</h3>
								<span class="event-detail event-detail--accent">
									<i aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 7a2 2 0 0 0 2-2h12a2 2 0 0 0 2 2v2a2 2 0 0 0 0 4v2a2 2 0 0 0-2 2H6a2 2 0 0 0-2-2v-2a2 2 0 0 0 0-4V7Z"/><path d="M9 8v8"/></svg></i>
									<strong>{event.status}</strong>
								</span>
								<span class="event-detail">
									<i aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M7 3v4M17 3v4M3 10h18M8 14h.01M12 14h.01M16 14h.01M8 17h.01M12 17h.01"/></svg></i>
									<span>{event.date}</span>
								</span>
								<span class="event-detail">
									<i aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="2.5"/></svg></i>
									<span>{event.place}</span>
								</span>
								<span class="event-card-link">Plačiau <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></span>
							</div>
						</a>
					</article>
				))}
			</div>
		</section>

		<section class="panel coach-section" id="treneris">
			<div class="coach-photo">
				<img
					src="/images/laikyti-mus-4.webp"
					alt="AJE+ komanda skateparke"
					loading="lazy"
				/>
			</div>
			<article class="coach-copy">
				<p class="eyebrow">06 / PRISIJUNK PRIE KOMANDOS</p>
				<h2>Nori tapti<br />treneriu?</h2>
				<p>Ieškome žmonių, kurie nori dalintis savo patirtimi, auginti jaunus riedėtojus ir kurti saugią bendruomenę.</p>
				<ol>
					<li><span>01</span>Išsirink sritį, kurioje norėtum save išbandyti.</li>
					<li><span>02</span>Parašyk mums trumpai apie save.</li>
					<li><span>03</span>Susitikime ir pasikalbėkime.</li>
				</ol>
				<a class="pill pill-yellow" href="mailto:ajeskatepark@gmail.com?subject=Noriu tapti treneriu">Parašyti komandai <span class="icon-arrow icon-arrow--up" aria-hidden="true"></span></a>
			</article>
		</section>

		<section class="panel support-section" id="prisidek">
			<div class="support-intro">
				<p class="eyebrow">07 / PARAMA</p>
				<h2>Paremk mūsų veiklą</h2>
				<p>Jūsų pagalba leidžia organizuoti daugiau nemokamų renginių, dirbtuvių ir veiklų jaunimui.</p>
			</div>
			<div class="support-grid">
				<a class="support-card gpm" href="mailto:ajeskatepark@gmail.com?subject=1,2% GPM">
					<span>01</span>
					<h3>Skirti 1,2% GPM</h3>
					<p>Nukreipkite dalį jau sumokėto pajamų mokesčio.</p>
					<b class="icon-arrow icon-arrow--up" aria-hidden="true"></b>
				</a>
				<a class="support-card donate" href="mailto:ajeskatepark@gmail.com?subject=Parama AJE+">
					<span>02</span>
					<h3>Paaukoti</h3>
					<p>Prisidėkite prie įrangos, renginių ir atvirų veiklų.</p>
					<b class="icon-arrow icon-arrow--up" aria-hidden="true"></b>
				</a>
				<a class="support-card volunteer" href="mailto:ajeskatepark@gmail.com?subject=Savanorystė AJE+">
					<span>03</span>
					<h3>Savanoriauti arba atlikti praktiką</h3>
					<p>Dalinkitės laiku, žiniomis ir idėjomis.</p>
					<b class="icon-arrow icon-arrow--up" aria-hidden="true"></b>
				</a>
			</div>
		</section>

		<section class="panel community-section" id="apie">
			<figure>
				<img
					src="/images/laikyti-mus-1.webp"
					alt="AJE+ bendruomenės nariai skateparke"
					loading="lazy"
				/>
				<figcaption>AJE+ BENDRUOMENĖ / KLAIPĖDA</figcaption>
			</figure>
			<article>
				<p class="meta">08 / APIE MUS</p>
				<h2>Tai daugiau nei skateparkas.</h2>
				<p>AJE+ yra atvira jaunimo erdvė, kurioje svarbūs ne tik triukai. Čia gali būti savimi, susitikti su bendraminčiais ir atrasti naują veiklą.</p>
				<ul>
					<li><span>01</span>Saugi erdvė</li>
					<li><span>02</span>Atviras darbas su jaunimu</li>
					<li><span>03</span>Bendruomenė</li>
					<li><span>04</span>Kūryba ir saviraiška</li>
				</ul>
				<a class="pill pill-yellow" href="#komanda">Susipažinti su komanda <span class="icon-arrow" aria-hidden="true"></span></a>
			</article>
		</section>

		<section class="panel team-section" id="komanda">
			<div class="section-title-row compact">
				<div>
					<p class="eyebrow">09 / ŽMONĖS, KURIE YRA ŠALIA</p>
					<h2>Komanda</h2>
				</div>
				<div class="carousel-controls">
					<button type="button" data-team-prev aria-label="Ankstesni komandos nariai"><span class="icon-arrow icon-arrow--left" aria-hidden="true"></span></button>
					<button type="button" data-team-next aria-label="Kiti komandos nariai"><span class="icon-arrow" aria-hidden="true"></span></button>
				</div>
			</div>
			<div class="team-track" data-team-track>
				{team.map((member) => (
					<article class:list={['team-card', { featured: member.featured }]}>
						<figure><img src={member.image} alt="" loading="lazy" /></figure>
						<h3>{member.name}</h3>
						<p>{member.role}</p>
					</article>
				))}
			</div>
		</section>

		<section class="panel visit-section" id="kontaktai">
			<div class="visit-copy">
				<p class="eyebrow">10 / KAIP MUS RASTI</p>
				<h2>Susitinkam parke</h2>
				<div class="contact-grid">
					<div><i class="contact-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="2.5"/></svg></i><span>Adresas</span><strong>Gluosnių skg. 2A-k2<br />Klaipėda, 91250</strong></div>
					<div><i class="contact-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7.2 3.5 10 7.8 7.8 10c1.4 3 3.3 4.9 6.2 6.2l2.2-2.2 4.3 2.8v3c0 .7-.5 1.2-1.2 1.2C10.3 21 3 13.7 3 4.7c0-.7.5-1.2 1.2-1.2h3Z"/></svg></i><span>Telefonas</span><a href="tel:+37065183405">+370 651 83405</a></div>
					<div><i class="contact-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg></i><span>El. paštas</span><a href="mailto:ajeskatepark@gmail.com">ajeskatepark@gmail.com</a></div>
					<div><i class="contact-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 21V3h10v18M15 9h4v12M8 7h4M8 11h4M8 15h4M3 21h18"/></svg></i><span>Organizacija</span><strong>Asmenybės ugdymo<br />kultūros centras, VšĮ</strong></div>
				</div>
