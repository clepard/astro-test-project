	/* Full-screen navigation */
	.utility-header {
		transition:
			transform 520ms cubic-bezier(.34, 1.45, .64, 1),
			box-shadow 220ms ease;
		will-change: transform;
	}

	.utility-header.is-hidden {
		pointer-events: none;
		transform: translate(-50%, calc(-100% - 32px));
		transition-timing-function: cubic-bezier(.4, 0, 1, 1), ease;
		transition-duration: 360ms, 220ms;
	}

	.utility-inner {
		display: flex;
		justify-content: space-between;
		gap: 20px;
	}

	.mini-logo {
		flex: none;
	}

	.mini-logo img {
		width: 76px;
		height: 42px;
		object-fit: contain;
	}

	.utility-actions {
		display: flex;
		align-items: center;
		gap: 18px;
	}

	.schedule-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 38px;
		padding: 9px 16px;
		border-radius: 999px;
		background: var(--violet);
		color: var(--white);
		font-size: .7rem;
		font-weight: 700;
		letter-spacing: .02em;
	}

	.menu-button {
		justify-content: flex-end;
	}

	.menu-overlay {
		position: fixed;
		z-index: 100;
		inset: 0;
		display: block;
		overflow: hidden;
		background: var(--yellow);
		opacity: 1;
		visibility: hidden;
		pointer-events: none;
		transform: translateX(100%);
		transition:
			transform 460ms cubic-bezier(.76, 0, .24, 1),
			visibility 0s linear 460ms;
	}

	.menu-overlay.open {
		visibility: visible;
		pointer-events: auto;
		transform: translateX(0);
		transition:
			transform 460ms cubic-bezier(.76, 0, .24, 1),
			visibility 0s;
	}

	.fullscreen-menu {
		display: flex;
		flex-direction: column;
		width: 100%;
		height: 100dvh;
		min-height: 0;
		padding: 24px clamp(24px, 4vw, 64px) 28px;
	}

	.menu-top {
		flex: none;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 24px;
		padding-bottom: 18px;
		border-bottom: 2px solid var(--ink);
	}

	.menu-logo {
		display: block;
		width: 92px;
		text-decoration: none;
	}

	.menu-top p,
	.menu-contact p {
		font-family: 'IBM Plex Mono', monospace;
		font-size: .68rem;
		font-weight: 600;
		letter-spacing: .08em;
		text-transform: uppercase;
	}

	.menu-top p {
		margin: 0;
		text-align: center;
	}

	.menu-top button {
		justify-self: end;
		width: max-content;
	}

	.fullscreen-nav {
		flex: 1;
		min-height: 0;
		width: min(100%, 1120px);
		margin: 0 auto;
		padding: clamp(24px, 4vh, 48px) 22px clamp(24px, 4vh, 48px) 0;
		overflow-y: auto;
		scrollbar-gutter: stable;
		scrollbar-width: thin;
		scrollbar-color: var(--ink) transparent;
	}

	.nav-group,
	.nav-main-link {
		border-bottom: 1px solid rgba(17, 17, 17, .45);
	}

	.nav-group {
		border-bottom: 0;
	}

	.nav-main-link:has(+ .nav-group) {
		border-bottom: 0;
	}

	.nav-group:first-child {
		border-top: 0;
	}

	.nav-group-trigger,
	.nav-main-link {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		width: 100%;
		min-height: clamp(68px, 9vh, 104px);
		padding: 8px 4px;
		border: 0;
		background: transparent;
		color: var(--ink);
		font: inherit;
		font-size: clamp(2.35rem, 5vw, 5rem);
		font-weight: 700;
		line-height: .95;
		letter-spacing: -.065em;
		text-align: left;
		text-decoration: none;
		cursor: pointer;
		transition: padding 180ms ease;
	}

	.nav-chevron {
		position: relative;
		width: clamp(24px, 3vw, 40px);
		height: clamp(24px, 3vw, 40px);
		margin-right: 8px;
		border: 1.5px solid var(--ink);
		border-radius: 50%;
		transition:
			transform 260ms ease,
			background 220ms ease;
	}

	.nav-chevron::before,
	.nav-chevron::after {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 42%;
		height: 1.5px;
		background: currentColor;
		content: '';
		transform: translate(-50%, -50%);
	}

	.nav-chevron::after {
		transform: translate(-50%, -50%) rotate(90deg);
		transition: opacity 180ms ease;
	}

	.nav-group.open .nav-chevron {
		background: var(--ink);
		color: var(--yellow);
		transform: rotate(180deg);
	}

	.nav-group.open .nav-chevron::after {
		opacity: 0;
	}

	.nav-main-link::after {
		width: clamp(24px, 3vw, 40px);
		margin-right: 8px;
		content: '↗';
		font-family: 'IBM Plex Mono', monospace;
		font-size: clamp(1rem, 1.7vw, 1.5rem);
		font-weight: 500;
		letter-spacing: 0;
		text-align: center;
		transition: transform 180ms ease;
	}

	.nav-group-trigger:hover,
	.nav-main-link:hover {
		padding-left: 12px;
	}

	.nav-main-link:hover::after {
		transform: translate(4px, -4px);
	}

	.nav-submenu {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 320ms cubic-bezier(.22, 1, .36, 1);
	}

	.nav-submenu > div {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		overflow: hidden;
		padding: 0 50px 0 4px;
		transition: padding-bottom 320ms cubic-bezier(.22, 1, .36, 1);
	}

	.nav-group.open .nav-submenu {
		grid-template-rows: 1fr;
	}

	.nav-group.open .nav-submenu > div {
		padding-bottom: 20px;
	}

	.nav-submenu a {
		padding: 9px 14px;
		border: 1px solid var(--ink);
		border-radius: 999px;
		color: var(--ink);
		font-family: 'IBM Plex Mono', monospace;
		font-size: clamp(.75rem, 1.1vw, .9rem);
		font-weight: 600;
		line-height: 1.2;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			color 180ms ease,
			background 180ms ease;
	}

	.nav-submenu a:hover {
		background: var(--ink);
		color: var(--yellow);
	}

	.menu-bottom {
		flex: none;
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 24px;
		padding-top: 18px;
		border-top: 2px solid var(--ink);
	}

	.menu-contact {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 20px;
	}

	.menu-contact p {
		margin: 0;
	}

	.menu-contact a {
		color: inherit;
	}

	.menu-actions {
		display: flex;
		gap: 8px;
	}

	@media (max-width: 760px) {
		.utility-inner {
			grid-template-columns: none;
			padding: 0 12px;
		}

		.mini-logo img {
			width: 62px;
			height: 36px;
		}

		.utility-actions {
			gap: 12px;
		}

		.schedule-link {
			min-height: 36px;
			padding: 8px 13px;
			font-size: .62rem;
		}

		.menu-button > span:first-child {
			display: inline;
		}

		.menu-button > span:last-child {
			display: grid;
		}

		.fullscreen-menu {
			padding: 18px 18px 20px;
		}

		.menu-top {
			grid-template-columns: 1fr auto;
			gap: 12px;
			padding-bottom: 14px;
		}

		.menu-top p {
			display: none;
		}

		.menu-logo {
			width: 64px;
		}

		.fullscreen-nav {
			width: 100%;
			margin: 16px 0;
			padding: 0 14px 0 0;
		}

		.nav-group-trigger,
		.nav-main-link {
			grid-template-columns: minmax(0, 1fr) auto;
			min-height: 59px;
			padding: 8px 0;
			font-size: clamp(1.7rem, 8vw, 2.45rem);
			letter-spacing: -.055em;
		}

		.nav-group-trigger:hover,
		.nav-main-link:hover {
			padding-left: 0;
		}

		.nav-chevron,
		.nav-main-link::after {
			width: 27px;
			height: 27px;
			margin-right: 2px;
		}

		.nav-submenu > div {
			display: grid;
			gap: 0;
			padding: 0;
		}

		.nav-group.open .nav-submenu > div {
			padding-bottom: 12px;
		}

		.nav-submenu a {
			padding: 8px 0;
			border: 0;
			border-bottom: 1px solid rgba(17, 17, 17, .3);
			border-radius: 0;
			font-size: .82rem;
			line-height: 1.35;
		}

		.menu-bottom {
			align-items: stretch;
			gap: 12px;
			padding-top: 14px;
		}

		.menu-contact {
			display: grid;
			gap: 4px;
		}

		.menu-contact p:nth-child(2) {
			display: none;
		}

		.menu-actions {
			align-items: flex-end;
		}

		.menu-actions .button {
			min-height: 40px;
			padding: 9px 13px;
			font-size: .68rem;
		}
	}

	/* Compact editorial carousels */
	.editorial-carousel {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.compact-card {
		min-width: 0;
		overflow: hidden;
		border: 1px solid var(--ink);
		border-radius: 10px;
		background: var(--cream);
	}

	.compact-card-heading {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 20px;
		padding: 20px;
	}

	.compact-card-heading h3 {
		max-width: 62%;
		margin: 0;
		font-size: clamp(1.45rem, 2.3vw, 2.35rem);
		font-weight: 650;
		letter-spacing: -.055em;
		line-height: 1;
	}

	.compact-card-heading p {
		display: flex;
		flex-direction: column;
		gap: 5px;
		margin: 3px 0 0;
		font-size: .62rem;
		line-height: 1.4;
		text-align: right;
	}

	.compact-card-heading p span {
		color: var(--muted);
	}

	.compact-card-image {
		position: relative;
		display: block;
		overflow: hidden;
		border-top: 1px solid var(--ink);
		background: var(--stone);
	}

	.camp-carousel .compact-card-image {
		aspect-ratio: 1 / 1;
	}

	.camp-card {
		display: grid;
		grid-template-rows: 1fr auto;
	}

	.camp-card-heading {
		padding: 22px;
	}

	.camp-card-heading > div {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 18px;
	}

	.camp-card-heading h3 {
		margin: 0;
		font-size: clamp(1.5rem, 2.3vw, 2.35rem);
		font-weight: 700;
		letter-spacing: -.055em;
		line-height: 1;
		text-transform: uppercase;
	}

	.camp-card-heading strong {
		flex: none;
		color: var(--muted);
		font-size: clamp(1rem, 1.7vw, 1.45rem);
		font-weight: 500;
	}

	.camp-card-heading > p {
		max-width: 92%;
		margin: 22px 0 0;
		color: var(--muted);
		font-size: .8rem;
		line-height: 1.5;
	}

	.camp-card-cta {
		position: absolute;
		right: 18px;
		bottom: 18px;
		display: inline-flex;
		align-items: center;
		gap: 24px;
		padding: 13px 18px;
		border: 1px solid var(--yellow);
		border-radius: 999px;
		background: var(--cream);
		color: var(--ink);
		font-size: .78rem;
		font-weight: 650;
		transition: color 180ms ease, background 180ms ease;
	}

	.compact-card-image:hover .camp-card-cta {
		color: var(--white);
		background: var(--violet);
	}

	.event-carousel .compact-card-image {
		aspect-ratio: 16 / 10;
	}

	.event-card > a {
		display: block;
		height: 100%;
	}

	.event-card-image {
		aspect-ratio: 16 / 9;
		display: block;
		overflow: hidden;
		border-bottom: 1px solid var(--ink);
		background: var(--stone);
	}

	.event-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(.78) contrast(1.04);
		transition: transform 350ms ease, filter 350ms ease;
	}

	.event-card:hover .event-card-image img {
		transform: scale(1.035);
		filter: saturate(.95) contrast(1.04);
	}

	.event-card-body {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 20px;
	}

	.event-card-body h3 {
		margin: 0 0 6px;
		font-size: clamp(1.55rem, 2.4vw, 2.35rem);
		font-weight: 650;
		letter-spacing: -.055em;
		line-height: 1;
	}

	.event-detail {
		display: grid;
		grid-template-columns: 28px 1fr;
		gap: 8px;
		align-items: center;
		color: var(--muted);
		font-size: .76rem;
		line-height: 1.4;
	}

	.event-detail--accent {
		color: var(--violet);
	}

	.event-detail i {
		width: 28px;
		height: 28px;
		display: grid;
		place-items: center;
		font-style: normal;
	}

	.event-detail svg {
		width: 24px;
		height: 24px;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.event-card-link {
		display: inline-flex;
		align-items: center;
		align-self: flex-start;
		gap: 8px;
		margin-top: 4px;
		padding-bottom: 3px;
		border-bottom: 1px solid;
		font-size: .7rem;
		font-weight: 700;
		letter-spacing: .06em;
		text-transform: uppercase;
	}

	.compact-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(.78) contrast(1.04);
		transition: transform 350ms ease, filter 350ms ease;
	}

	.compact-card-shade {
		position: absolute;
		inset: 45% 0 0;
		background: linear-gradient(0deg, rgba(17, 17, 17, .72), transparent);
	}

	.compact-card-image > .text-link {
		position: absolute;
		left: 18px;
		bottom: 18px;
		color: var(--white);
	}

	.compact-card-image:hover img {
		transform: scale(1.035);
		filter: saturate(.95) contrast(1.04);
	}

	/* Support section: compact action rows */
	.support-section {
		display: grid;
		grid-template-columns: minmax(260px, .8fr) minmax(0, 1.55fr);
		gap: clamp(42px, 7vw, 100px);
		align-items: start;
	}

	.support-intro {
		display: flex;
		flex-direction: column;
		gap: 26px;
		margin: 0;
	}

	.support-intro h2,
	.support-intro > p:last-child {
		margin: 0;
	}

	.support-grid {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-top: 1px solid rgba(255, 255, 255, .55);
	}

	.support-section .support-card {
		min-height: 156px;
		display: grid;
		grid-template-columns: 42px minmax(170px, .9fr) minmax(180px, 1fr) 20px;
		align-items: center;
		gap: 20px;
		padding: 24px 8px;
		color: var(--white);
		border: 0;
		border-bottom: 1px solid rgba(255, 255, 255, .55);
		border-radius: 0;
		background: transparent;
		transition: color 220ms ease, background 220ms ease, padding 220ms ease;
	}

	.support-section .support-card:hover {
		padding-inline: 20px;
		color: var(--ink);
		background: var(--yellow);
		transform: none;
	}

