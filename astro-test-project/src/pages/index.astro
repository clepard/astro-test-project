	/* Final content hierarchy and interaction refinements */
	:global(main) {
		padding-top: 76px;
	}

	.icon-arrow {
		width: 15px;
		height: 10px;
		position: relative;
		display: inline-block;
		flex: 0 0 auto;
	}

	.icon-arrow::before {
		content: '';
		width: 100%;
		height: 1.5px;
		position: absolute;
		left: 0;
		top: 50%;
		background: currentColor;
		transform: translateY(-50%);
	}

	.icon-arrow::after {
		content: '';
		width: 6px;
		height: 6px;
		position: absolute;
		right: 0;
		top: 50%;
		border-top: 1.5px solid currentColor;
		border-right: 1.5px solid currentColor;
		transform: translateY(-50%) rotate(45deg);
	}

	.icon-arrow--up {
		transform: rotate(-45deg);
	}

	.icon-arrow--left {
		transform: rotate(180deg);
	}

	.icon-arrow--vertical {
		margin-left: 4px;
		transform: rotate(-90deg);
	}

	.close-icon {
		width: 18px;
		height: 18px;
		position: relative;
		display: inline-block;
	}

	.close-icon::before,
	.close-icon::after {
		content: '';
		width: 20px;
		height: 2px;
		position: absolute;
		left: -1px;
		top: 8px;
		background: currentColor;
	}

	.close-icon::before { transform: rotate(45deg); }
	.close-icon::after { transform: rotate(-45deg); }

	.menu-overlay {
		inset: 0;
		display: block;
		padding: 0;
		background: transparent;
		visibility: hidden;
		opacity: 1;
		pointer-events: none;
		transform: none;
		transition: visibility .55s;
	}

	.menu-overlay.open {
		visibility: visible;
		pointer-events: auto;
	}

	.menu-backdrop {
		position: absolute;
		inset: 0;
		border: 0;
		background: rgba(17,17,17,.58);
		opacity: 0;
		cursor: pointer;
		transition: opacity .38s ease;
	}

	.menu-overlay.open .menu-backdrop {
		opacity: 1;
	}

	.menu-drawer {
		width: min(620px, 92vw);
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
		display: flex;
		flex-direction: column;
		padding: clamp(24px, 4vw, 48px);
		background: var(--yellow);
		box-shadow: 30px 0 70px rgba(17,17,17,.22);
		transform: translateX(-105%);
		transition: transform .55s cubic-bezier(.76,0,.24,1);
	}

	.menu-overlay.open .menu-drawer {
		transform: none;
	}

	.drawer-links {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 28px 0;
		overflow-y: auto;
	}

	.drawer-links a {
		display: grid;
		grid-template-columns: 38px 1fr;
		gap: 10px;
		align-items: baseline;
		padding: 10px 0;
		border-bottom: 1px solid rgba(17,17,17,.28);
		font-size: clamp(1.35rem, 3vw, 2.4rem);
		font-weight: 650;
		letter-spacing: -.045em;
		line-height: 1.05;
		transition: padding .2s, color .2s;
	}

	.drawer-links a:hover {
		padding-left: 8px;
		color: var(--violet);
	}

	.drawer-links a span {
		font-size: .58rem;
		font-weight: 700;
		letter-spacing: .05em;
	}

	.hero-section {
		min-height: min(780px, calc(100svh - 112px));
		position: relative;
		display: flex;
		align-items: center;
		padding: clamp(40px, 6vw, 78px);
		color: var(--white);
		isolation: isolate;
	}

	.hero-photo,
	.hero-shade {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.hero-photo {
		z-index: -2;
		object-fit: cover;
		object-position: center 48%;
		filter: saturate(.78) contrast(1.06);
	}

	.hero-shade {
		z-index: -1;
		background:
			linear-gradient(90deg, rgba(17,17,17,.9) 0%, rgba(17,17,17,.64) 42%, rgba(17,17,17,.08) 76%),
			linear-gradient(0deg, rgba(17,17,17,.38), transparent 45%);
	}

	.hero-content {
		width: min(690px, 58%);
	}

	.hero-kicker {
		margin: 0 0 26px;
		color: var(--yellow);
		font-size: .68rem;
		font-weight: 750;
		letter-spacing: .1em;
	}

	.hero-content h1 {
		margin: 0;
		font-size: clamp(3.4rem, 6.7vw, 6.7rem);
		font-weight: 720;
		letter-spacing: -.075em;
		line-height: .93;
	}

	.hero-content > p:not(.hero-kicker) {
		max-width: 610px;
		margin: 28px 0 30px;
		color: rgba(255,253,247,.82);
		font-size: clamp(.9rem, 1.25vw, 1.08rem);
		line-height: 1.65;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.pill-yellow {
		color: var(--ink);
		border-color: var(--yellow);
		background: var(--yellow);
	}

	.pill-yellow:hover {
		color: var(--white);
		border-color: var(--violet);
		background: var(--violet);
	}

	.pill-light {
		color: var(--white);
		border-color: rgba(255,255,255,.75);
		background: rgba(17,17,17,.18);
		backdrop-filter: blur(8px);
	}

	.pill-light:hover {
		color: var(--ink);
		border-color: var(--white);
		background: var(--white);
	}

	.hero-location {
		position: absolute;
		right: 34px;
		bottom: 30px;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 12px 15px;
		color: var(--ink);
		background: var(--yellow);
		font-size: .62rem;
	}

	.hero-location strong {
		font-size: .75rem;
	}

	.sessions-layout {
		display: grid;
		grid-template-columns: 7fr 5fr;
		border: 1px solid var(--ink);
		border-radius: 10px;
		overflow: hidden;
	}

	.sessions-photo {
		min-height: 520px;
		position: relative;
		margin: 0;
		overflow: hidden;
	}

	.sessions-photo img {
		height: 100%;
		object-fit: cover;
		filter: saturate(.72) contrast(1.05);
	}

	.sessions-photo figcaption {
		position: absolute;
		left: 16px;
		bottom: 16px;
		padding: 8px 10px;
		background: var(--yellow);
		font-size: .6rem;
		font-weight: 750;
		letter-spacing: .06em;
	}

	.session-info {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		padding: clamp(32px, 5vw, 62px);
		background: var(--yellow);
	}

	.session-info .meta {
		margin: 0 0 40px;
	}

	.session-info h3 {
		margin: 0 0 26px;
		font-size: clamp(2rem, 3.4vw, 3.5rem);
		font-weight: 650;
		letter-spacing: -.06em;
		line-height: 1;
	}

	.session-rows {
		width: 100%;
		margin-bottom: 30px;
	}

	.session-rows > div {
		display: grid;
		grid-template-columns: 125px 1fr;
		gap: 16px;
		padding: 11px 0;
		border-top: 1px solid rgba(17,17,17,.5);
		font-size: .69rem;
		line-height: 1.45;
	}

	.session-rows span {
		color: rgba(17,17,17,.62);
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 18px;
	}

	.service-card {
		min-width: 0;
		display: grid;
		grid-template-columns: 1.05fr .95fr;
		min-height: 310px;
		border: 1px solid var(--ink);
		border-radius: 10px;
		overflow: hidden;
	}

	.service-card figure {
		position: relative;
		margin: 0;
		overflow: hidden;
	}

	.service-card figure img {
		height: 100%;
		object-fit: cover;
		filter: saturate(.76) contrast(1.04);
		transition: transform .35s;
	}

	.service-card:hover figure img {
		transform: scale(1.035);
	}

	.service-card figure span {
		position: absolute;
		top: 12px;
		left: 12px;
		padding: 6px 8px;
		color: var(--white);
		background: var(--ink);
		font-size: .58rem;
		font-weight: 700;
	}

	.service-card-copy {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 20px;
		background: var(--yellow);
	}

	.service-card:nth-child(even) .service-card-copy {
		background: var(--stone);
	}

	.service-card-copy .meta {
		margin: 0 0 auto;
	}

	.service-card-copy h3 {
		margin: 24px 0 10px;
		font-size: clamp(1.55rem, 2.4vw, 2.4rem);
		font-weight: 650;
		letter-spacing: -.05em;
		line-height: 1;
	}

	.service-card-copy > p:not(.meta) {
		margin: 0;
		color: #5f5a52;
		font-size: .72rem;
