---
import Layout from '../layouts/Layout.astro';

const slides = [
	{ number: '01', title: 'Solar Drift', kicker: 'Sahara · Morocco', copy: 'Move through a landscape shaped by light, wind, and an endless horizon.', theme: 'sunset', stat: '32°C', label: 'Golden hour' },
	{ number: '02', title: 'Silent North', kicker: 'Lofoten · Norway', copy: 'Find sharp peaks, glassy water, and small moments of perfect northern calm.', theme: 'arctic', stat: '68°N', label: 'Polar escape' },
	{ number: '03', title: 'After Dark', kicker: 'Tokyo · Japan', copy: 'Follow the electric pulse through side streets, rooftops, and midnight color.', theme: 'neon', stat: '2:14', label: 'Night edition' },
	{ number: '04', title: 'Wild Current', kicker: 'Madeira · Portugal', copy: 'Trace the Atlantic edge where deep green cliffs fall into restless blue.', theme: 'ocean', stat: '740m', label: 'Above sea' },
	{ number: '05', title: 'Soft Geometry', kicker: 'Cappadocia · Türkiye', copy: 'Float over ancient stone formations as the first morning colors appear.', theme: 'clay', stat: '05:40', label: 'First flight' },
];
---

<Layout title="Elsewhere — Immersive Carousel">
	<main class="page">
		<div class="ambient ambient--one"></div>
		<div class="ambient ambient--two"></div>

		<header class="site-header">
			<a class="brand" href="#top" aria-label="Elsewhere home">
				<span class="brand-mark">E</span>
				<span>ELSEWHERE</span>
			</a>
			<p>Curated escapes for curious minds</p>
			<button class="menu-button" type="button" aria-label="Open menu"><span></span><span></span></button>
		</header>

		<section class="hero" id="top" aria-labelledby="page-title">
			<div class="intro">
				<p class="eyebrow"><span></span> Selected journeys · 2026</p>
				<h1 id="page-title">Go where you<br /><em>feel alive.</em></h1>
				<p class="intro-copy">Five extraordinary places. One fluid journey. Drag, swipe, or use the arrows to explore.</p>
			</div>

			<div class="carousel" data-carousel tabindex="0" aria-roledescription="carousel" aria-label="Featured destinations">
				<div class="carousel-track" data-track>
					{slides.map((slide, index) => (
						<article class:list={['card', `card--${slide.theme}`, { active: index === 0 }]} data-slide data-index={index} aria-label={`${index + 1} of ${slides.length}: ${slide.title}`}>
							<div class="card-surface">
								<div class="card-art" aria-hidden="true">
									<div class="orb"></div><div class="horizon"></div><div class="grain"></div>
								</div>
								<div class="card-shade"></div>
								<header class="card-top"><span>{slide.number}</span><span>{slide.label}</span></header>
								<div class="card-content">
									<p>{slide.kicker}</p>
									<h2>{slide.title}</h2>
									<div class="card-detail">
										<p>{slide.copy}</p>
										<a href={`#${slide.theme}`} aria-label={`Explore ${slide.title}`}>Explore <span>↗</span></a>
									</div>
								</div>
								<div class="card-stat"><strong>{slide.stat}</strong></div>
							</div>
						</article>
					))}
				</div>
			</div>

			<div class="controls">
				<div class="arrow-group">
					<button class="arrow" type="button" data-prev aria-label="Previous destination">←</button>
					<button class="arrow" type="button" data-next aria-label="Next destination">→</button>
				</div>
				<div class="progress-wrap">
					<span class="current" data-current>01</span>
					<div class="progress"><span data-progress></span></div>
					<span>0{slides.length}</span>
				</div>
				<button class="pause" type="button" data-pause aria-label="Pause autoplay"><span>Ⅱ</span> Auto journey</button>
			</div>
		</section>

		<footer class="footer"><span>Scroll to explore</span><span>Built with Astro + motion</span></footer>
	</main>
</Layout>

<script>
	const root = document.querySelector<HTMLElement>('[data-carousel]')!;
	const track = document.querySelector<HTMLElement>('[data-track]')!;
	const cards = [...document.querySelectorAll<HTMLElement>('[data-slide]')];
	const prev = document.querySelector<HTMLButtonElement>('[data-prev]')!;
	const next = document.querySelector<HTMLButtonElement>('[data-next]')!;
	const currentLabel = document.querySelector<HTMLElement>('[data-current]')!;
	const progress = document.querySelector<HTMLElement>('[data-progress]')!;
	const pause = document.querySelector<HTMLButtonElement>('[data-pause]')!;
	const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
	let activeIndex = 0;
	let autoplay = !reduceMotion;
	let timer = 0;
	let pointerStart = 0;
	let pointerNow = 0;
	let activePointer: number | null = null;
	let dragged = false;
	let viewportWidth = root.clientWidth;
	let resizeFrame = 0;

	function select(index: number, userInitiated = false) {
		activeIndex = (index + cards.length) % cards.length;
		cards.forEach((card, cardIndex) => {
			const active = cardIndex === activeIndex;
			let offset = cardIndex - activeIndex;
			if (offset > cards.length / 2) offset -= cards.length;
			if (offset < -cards.length / 2) offset += cards.length;
			const distance = Math.abs(offset);
			const step = Math.min(350, Math.max(190, root.clientWidth * 0.27));
			card.style.setProperty('--x', `${offset * step}px`);
			card.style.setProperty('--z', `${distance * -150}px`);
			card.style.setProperty('--rotate', `${offset * -7}deg`);
			card.style.setProperty('--card-scale', String(distance === 0 ? 1 : distance === 1 ? 0.82 : 0.66));
			card.style.setProperty('--card-opacity', String(distance === 0 ? 1 : distance === 1 ? 0.34 : 0.035));
			card.style.setProperty('--blur', `${distance === 2 ? 2 : 0}px`);
			card.style.zIndex = String(10 - distance);
			card.classList.toggle('active', active);
			card.setAttribute('aria-current', active ? 'true' : 'false');
		});
		currentLabel.textContent = String(activeIndex + 1).padStart(2, '0');
		progress.style.setProperty('--progress', `${((activeIndex + 1) / cards.length) * 100}%`);
		if (userInitiated) restartTimer();
	}

	function restartTimer() {
		window.clearInterval(timer);
		if (autoplay) timer = window.setInterval(() => select(activeIndex + 1), 4800);
	}

	prev.addEventListener('click', () => select(activeIndex - 1, true));
	next.addEventListener('click', () => select(activeIndex + 1, true));
	cards.forEach((card, index) => card.addEventListener('click', () => { if (!dragged && index !== activeIndex) select(index, true); }));
	root.addEventListener('keydown', (event) => {
		if (event.key === 'ArrowLeft') { event.preventDefault(); select(activeIndex - 1, true); }
		if (event.key === 'ArrowRight') { event.preventDefault(); select(activeIndex + 1, true); }
	});
	root.addEventListener('pointerdown', (event) => {
		if (activePointer !== null) return;
		activePointer = event.pointerId;
		pointerStart = pointerNow = event.clientX;
		dragged = false;
		window.clearInterval(timer);
		if (event.pointerType === 'mouse') root.setPointerCapture(event.pointerId);
		root.classList.add('dragging');
	});
	root.addEventListener('pointermove', (event) => {
		if (event.pointerId !== activePointer) return;
		pointerNow = event.clientX;
		dragged = Math.abs(pointerNow - pointerStart) > 8;
	});
	function finishSwipe(event: PointerEvent, cancelled = false) {
		if (event.pointerId !== activePointer) return;
		if (root.hasPointerCapture(event.pointerId)) root.releasePointerCapture(event.pointerId);
		root.classList.remove('dragging');
		const distance = pointerNow - pointerStart;
		activePointer = null;
		if (!cancelled && Math.abs(distance) > 45) select(activeIndex + (distance < 0 ? 1 : -1), true);
		else restartTimer();
		window.setTimeout(() => { dragged = false; }, 0);
	}
	root.addEventListener('pointerup', (event) => finishSwipe(event));
	root.addEventListener('pointercancel', (event) => finishSwipe(event, true));
	pause.addEventListener('click', () => {
		autoplay = !autoplay;
		pause.classList.toggle('paused', !autoplay);
		pause.querySelector('span')!.textContent = autoplay ? 'Ⅱ' : '▶';
		pause.setAttribute('aria-label', autoplay ? 'Pause autoplay' : 'Start autoplay');
		restartTimer();
	});
	document.addEventListener('visibilitychange', () => document.hidden ? window.clearInterval(timer) : restartTimer());
	window.addEventListener('resize', () => {
		window.cancelAnimationFrame(resizeFrame);
		resizeFrame = window.requestAnimationFrame(() => {
			const nextWidth = root.clientWidth;
			if (Math.abs(nextWidth - viewportWidth) < 3) return;
			viewportWidth = nextWidth;
			select(activeIndex);
		});
	});
	select(0); restartTimer();
</script>

<style>
	:global(:root) { --ink: #f4f0e8; --muted: rgba(244,240,232,.58); --line: rgba(255,255,255,.14); }
	:global(html) { scroll-behavior: smooth; }
	:global(body) { overflow-x: hidden; color: var(--ink); background: #090a0f; }
	:global(button), :global(a) { -webkit-tap-highlight-color: transparent; }
	:global(a) { color: inherit; text-decoration: none; }
	.page { min-height: 100vh; position: relative; overflow: hidden; isolation: isolate; background: radial-gradient(circle at 70% 15%, #1f2030 0, transparent 31%), linear-gradient(135deg, #111219, #07080c 70%); }
	.page::before { content: ''; position: absolute; inset: 0; z-index: -1; opacity: .28; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.18'/%3E%3C/svg%3E"); pointer-events: none; }
	.ambient { position: absolute; width: 520px; height: 520px; z-index: -1; border-radius: 50%; filter: blur(130px); opacity: .16; pointer-events: none; animation: float 12s ease-in-out infinite alternate; }
	.ambient--one { top: -300px; left: 5%; background: #e45d35; }
	.ambient--two { right: -240px; bottom: -250px; background: #4f67ff; animation-delay: -4s; }
	.site-header { width: min(1440px, calc(100% - 64px)); height: 110px; margin: auto; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--line); }
	.brand { display: flex; align-items: center; gap: 12px; font-size: .72rem; font-weight: 800; letter-spacing: .24em; }
	.brand-mark { width: 33px; height: 33px; display: grid; place-items: center; border: 1px solid rgba(255,255,255,.35); border-radius: 50%; font-family: Georgia, serif; font-size: 1rem; font-style: italic; }
	.site-header > p { color: var(--muted); font-size: .7rem; letter-spacing: .08em; text-transform: uppercase; }
	.menu-button { width: 44px; height: 44px; display: grid; place-content: center; gap: 6px; border: 1px solid var(--line); border-radius: 50%; background: transparent; cursor: pointer; transition: .25s; }
	.menu-button span { width: 17px; height: 1px; display: block; background: currentColor; transition: .25s; }
	.menu-button span:last-child { transform: translateX(4px); }
	.menu-button:hover { color: #111; background: #fff; transform: rotate(10deg); }
	.menu-button:hover span:last-child { transform: none; }
	.hero { width: min(1440px, calc(100% - 64px)); min-height: calc(100vh - 160px); margin: 0 auto; padding: clamp(36px, 5vh, 62px) 0 28px; display: grid; grid-template-rows: auto minmax(500px, 1fr) auto; align-items: center; }
	.intro { position: relative; z-index: 20; text-align: center; }
	.eyebrow { margin: 0 0 18px; display: flex; align-items: center; justify-content: center; gap: 11px; color: var(--muted); font-size: .67rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; }
	.eyebrow span { width: 26px; height: 1px; background: #ff7251; }
	h1 { margin: 0 auto; max-width: 900px; font-size: clamp(3.2rem, 5.8vw, 6.4rem); font-weight: 450; letter-spacing: -.075em; line-height: .88; }
	h1 em { color: #ff7658; font-family: Georgia, 'Times New Roman', serif; font-weight: 400; }
	.intro-copy { max-width: 500px; margin: 24px auto 0; color: var(--muted); font-size: clamp(.84rem, 1vw, .98rem); line-height: 1.7; }
	.carousel { width: 100%; height: min(59vh, 600px); min-height: 500px; position: relative; overflow: hidden; outline: 0; cursor: grab; perspective: 1200px; perspective-origin: 50% 48%; touch-action: pan-y; -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent); mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent); }
	.carousel.dragging { cursor: grabbing; }
	.carousel-track { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; }
	.card { --x: 0px; --z: 0px; --rotate: 0deg; --card-scale: 1; --card-opacity: 1; --blur: 0px; width: clamp(340px, 31vw, 480px); height: min(56vh, 560px); min-height: 460px; position: absolute; left: 50%; top: 50%; backface-visibility: hidden; -webkit-backface-visibility: hidden; cursor: pointer; opacity: var(--card-opacity); filter: blur(var(--blur)) saturate(calc(.65 + var(--card-opacity) * .35)) brightness(calc(.62 + var(--card-opacity) * .38)); transform: translate3d(calc(-50% + var(--x)), -50%, var(--z)) rotateY(var(--rotate)) scale(var(--card-scale)); -webkit-transform: translate3d(calc(-50% + var(--x)), -50%, var(--z)) rotateY(var(--rotate)) scale(var(--card-scale)); transform-origin: center; transition: transform .78s cubic-bezier(.18,.86,.22,1), opacity .24s ease-out, filter .28s ease-out, scale .35s cubic-bezier(.2,.8,.2,1); will-change: transform, opacity; }
	.card-surface { position: absolute; inset: 0; overflow: hidden; isolation: isolate; contain: paint; backface-visibility: hidden; -webkit-backface-visibility: hidden; border: 1px solid rgba(255,255,255,.17); border-radius: 24px; clip-path: inset(0 round 24px); background: #0b0c10; transform: translateZ(0); -webkit-transform: translateZ(0); transition: box-shadow .35s; }
	@media (hover: hover) and (pointer: fine) { .card:hover:not(.active) { scale: 1.08; opacity: min(1, calc(var(--card-opacity) + .2)); filter: blur(0) saturate(.9) brightness(.88); } }
	.card.active { opacity: 1; filter: none; transition: transform .78s cubic-bezier(.18,.86,.22,1), opacity .06s linear, filter .1s linear, scale .35s cubic-bezier(.2,.8,.2,1); }
	.card.active .card-surface { box-shadow: 0 35px 90px rgba(0,0,0,.58), 0 0 0 1px rgba(255,255,255,.08); }
	.card-art, .card-shade, .grain { position: absolute; inset: 0; }
	.card-art { overflow: hidden; background: var(--sky); }
	.card-art::before, .card-art::after { content: ''; position: absolute; transition: transform 1.2s cubic-bezier(.2,.8,.2,1); }
	.card-shade { background: linear-gradient(to bottom, rgba(0,0,0,.04) 25%, rgba(4,5,8,.82) 100%); }
	.grain { opacity: .2; mix-blend-mode: overlay; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
	.card:hover .card-art::before, .card.active .card-art::before { transform: scale(1.07) translateY(-8px); }
	.orb { position: absolute; width: 45%; aspect-ratio: 1; left: 27%; top: 19%; border-radius: 50%; background: var(--orb); box-shadow: 0 0 80px var(--glow); transition: transform .9s cubic-bezier(.2,.8,.2,1); }
	.card:hover .orb, .card.active .orb { transform: translateY(-13px) scale(1.08); }
	.horizon { position: absolute; left: -20%; right: -20%; bottom: -5%; height: 51%; border-radius: 50% 50% 0 0; background: var(--land); transform: rotate(var(--tilt, -4deg)); box-shadow: inset 0 25px 50px rgba(255,255,255,.08); }
	.card--sunset { --sky: linear-gradient(#38172a, #d74b32 58%, #f6a64f); --orb: #ffd27d; --glow: rgba(255,173,72,.7); --land: linear-gradient(150deg,#7b2e20,#1c0d17); --tilt: -7deg; }
	.card--arctic { --sky: linear-gradient(#9bc4ca, #d8e5df 55%, #6b8993); --orb: rgba(242,255,242,.9); --glow: rgba(220,255,246,.8); --land: linear-gradient(140deg,#334a57 0 26%,#e5eee8 27% 36%,#152b37 37%); --tilt: 4deg; }
	.card--neon { --sky: linear-gradient(#150d35, #46235f 60%, #ed4277); --orb: #ff4caf; --glow: rgba(255,47,181,.75); --land: repeating-linear-gradient(90deg,#131025 0 9%,#24244f 10% 18%); --tilt: 0deg; }
	.card--ocean { --sky: linear-gradient(#72c3c8, #228896 58%, #075466); --orb: #f7e09e; --glow: rgba(246,224,157,.5); --land: linear-gradient(145deg,#164e42,#072d32 55%,#031b29); --tilt: -11deg; }
	.card--clay { --sky: linear-gradient(#a9796d, #e7ad8f 62%, #f4d5a8); --orb: #ffe4b1; --glow: rgba(255,226,165,.7); --land: linear-gradient(150deg,#9a513b,#4e292d); --tilt: 6deg; }
	.card-top { position: absolute; z-index: 2; top: 30px; left: 27px; right: 27px; display: flex; justify-content: space-between; color: rgba(255,255,255,.72); font-size: .61rem; font-weight: 750; letter-spacing: .12em; text-transform: uppercase; }
	.card-top span:last-child { opacity: 0; transform: translateY(8px); transition: .14s; }
	.card.active .card-top span:last-child { opacity: 1; transform: none; }
	.card-content { position: absolute; z-index: 2; left: 27px; right: 27px; bottom: 28px; opacity: .28; transition: opacity .14s ease-out; }
	.card.active .card-content { opacity: 1; transition: opacity .12s linear; }
	.card-content > p { margin: 0 0 8px; white-space: nowrap; color: rgba(255,255,255,.65); font-size: .64rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
	.card h2 { margin: 0; white-space: nowrap; font-family: Georgia, serif; font-size: clamp(1.65rem, 2.4vw, 2.8rem); font-weight: 400; letter-spacing: -.035em; }
	.card-detail { max-height: 0; overflow: hidden; opacity: 0; transform: translateY(12px); transition: max-height .18s, opacity .1s, transform .16s; }
	.card.active .card-detail { max-height: 155px; opacity: 1; transform: none; transition: max-height .45s .08s, opacity .28s .15s, transform .35s .12s; }
	.card-detail p { max-width: 330px; margin: 17px 0 22px; color: rgba(255,255,255,.68); font-size: .81rem; line-height: 1.6; }
	.card-detail a { display: inline-flex; align-items: center; gap: 18px; padding-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,.6); font-size: .72rem; font-weight: 750; text-transform: uppercase; letter-spacing: .1em; }
	.card-detail a span { transition: transform .25s; }
	.card-detail a:hover span { transform: translate(4px,-4px); }
	.card-stat { position: absolute; z-index: 2; right: 25px; top: 50%; opacity: 0; transform: rotate(90deg) translateY(-10px); transform-origin: right top; color: rgba(255,255,255,.5); font-size: .68rem; letter-spacing: .14em; transition: .16s; }
	.card.active .card-stat { opacity: 1; transform: rotate(90deg); }
	.controls { width: min(920px, 100%); margin: 0 auto; display: grid; grid-template-columns: auto 1fr; gap: clamp(25px, 5vw, 75px); align-items: center; }
	.arrow-group { display: flex; gap: 10px; }
	.arrow { width: 50px; height: 50px; border: 1px solid var(--line); border-radius: 50%; color: #fff; background: transparent; cursor: pointer; transition: .25s; }
	.arrow:hover { color: #0b0c10; background: #fff; transform: translateY(-3px); }
	.progress-wrap { display: grid; grid-template-columns: 25px minmax(100px, 1fr) 25px auto; align-items: center; gap: 16px; color: var(--muted); font-size: .68rem; }
	.current { color: #fff; }
	.progress { height: 1px; background: rgba(255,255,255,.15); }
	.progress span { width: var(--progress, 20%); height: 100%; display: block; background: #ff7658; transition: width .65s cubic-bezier(.2,.8,.2,1); }
	.pause { justify-self: end; display: flex; align-items: center; gap: 9px; border: 0; color: var(--muted); background: transparent; font-size: .65rem; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; }
	.pause span { color: #ff7658; font-size: .72rem; }
	.footer { width: min(1440px, calc(100% - 64px)); min-height: 50px; margin: auto; display: flex; justify-content: space-between; color: rgba(255,255,255,.3); font-size: .6rem; letter-spacing: .12em; text-transform: uppercase; }
	@keyframes float { to { transform: translate(90px,60px) scale(1.15); } }
	@media (max-width: 950px) {
		.site-header { height: 88px; }
		.site-header > p { display: none; }
		.hero { min-height: auto; padding-top: 46px; grid-template-rows: auto minmax(510px, 60vh) auto; }
		.intro { margin-bottom: 12px; }
		h1 { font-size: clamp(3.7rem, 12vw, 6rem); }
		.intro-copy { max-width: 520px; }
		.carousel { width: calc(100vw - 20px); margin-left: calc((100% - 100vw + 20px) / 2); height: min(58vh, 560px); }
		.card { width: min(66vw, 440px); height: min(55vh, 535px); }
		.controls { grid-template-columns: auto 1fr; gap: 25px; }
		.progress-wrap { grid-template-columns: 25px 1fr 25px; }
		.pause { display: none; }
	}
	@media (max-width: 560px) {
		.site-header, .hero, .footer { width: calc(100% - 36px); }
		.site-header { height: 76px; }
		.hero { padding-top: 34px; grid-template-rows: auto 500px auto; }
		.eyebrow { margin-bottom: 17px; }
		h1 { font-size: clamp(3.35rem, 15vw, 4.7rem); }
		.intro-copy { margin-top: 24px; font-size: .85rem; }
		.carousel { width: 100vw; height: 480px; min-height: 480px; margin-left: -18px; -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent); }
		.carousel { perspective: none; }
		.carousel-track { transform-style: flat; }
		.card { width: min(72vw, 320px); height: 455px; min-height: 455px; filter: none; transform: translate3d(calc(-50% + var(--x)), -50%, 0) scale(var(--card-scale)); -webkit-transform: translate3d(calc(-50% + var(--x)), -50%, 0) scale(var(--card-scale)); transition: transform .52s cubic-bezier(.2,.78,.25,1), opacity .2s ease-out; }
		.card.active { transition: transform .52s cubic-bezier(.2,.78,.25,1), opacity .04s linear; }
		.card-surface { border-radius: 20px; clip-path: inset(0 round 20px); }
		.controls { margin-bottom: 45px; }
		.arrow { width: 44px; height: 44px; }
		.footer { display: none; }
	}
	@media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: .01ms !important; scroll-behavior: auto !important; transition-duration: .01ms !important; } }
</style>
